<section id="hero" class="flex flex-col w-auto relative overflow-hidden md:flew-row">
    <!-- 背景层：绝对定位，铺满父容器，添加模糊 -->
    <div class="absolute inset-0 bg-center bg-cover overflow-hidden filter blur-xs scale-105" style="background-image: url('{{ metadata.hero.heroBackgroundImg }}')"></div>

    <!-- container wrap -->
    <div class="flex flex-col relative mx-auto z-10 p-6 m-0 py-12 text-white md:flex-row md:justify-center md:w-4xl">
        <div class="flex felx-col justify-center">
            {% if metadata.hero.title %}
                <h1 class="mb-4 text-6xl text-shadow-lg font-bold md:text-8xl">{{ metadata.hero.title }}</h1>
            {% endif %}
        </div>
        <div class="container">
            {% if metadata.hero.text %}
                <div class="mx-auto md:pt-12">
                    {% for line in metadata.hero.text %}
                    {{ line | markdown | safe }}
                    {% endfor %}
                </div>
            {% endif %}
            {% if metadata.hero.buttons %}
                <div class="mx-auto flex-row m-6">
                    {% for button in metadata.hero.buttons %}
                        <a href="{{ button.link }}"
                        class="inline-block
                        text-neutral-100 text-sm h-9
                        font-bold p-2 px-4 mr-3
                        bg-blue-500 transition delay-150 duration-300 ease-in-out hover:-translate-y-1 hover:scale-110 hover:bg-indigo-500
                        rounded-full shadow-lg
                        ">{{ button.lable }}</a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
    
</section>
