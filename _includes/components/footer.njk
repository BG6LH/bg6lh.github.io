<section class="flex flex-col max-w-4xl mx-auto p-0 py-12
            grid grid-cols-1 gap-6
            text-xs text-center justify-center
            md:flex-row md:grid-cols-3 md:text-left md:justify-start
        ">

    <!-- 基本信息 -->
    <div class="flex flex-col items-center md:items-start">
    <h3 class="font-bold mb-4">BG6LH</h3>
        <img src="/img/qrcode_for_bg6lh.jpg" alt="" class="w-32 sm:w-32">
        <div class="">
            <p>{{ metadata.copyrightText }}</p>
        </div>
    </div>

    <!-- 网站栏目 -->
    <div class="">
        <h3 class="font-bold mb-4">网站栏目</h3>
        <nav>
            <ul class="list-none">
                {%- for entry in collections.all | eleventyNavigation %}
                <li class=""><a href="{{ entry.url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>{{ entry.title }}</a></li>
                {%- endfor %}
            </ul>
        </nav>
    </div>


    <!-- 社交媒体 -->
    <div class="">
        <h3 class="font-bold mb-4">Social Links</h3>
        <div class="flex gap-6">
            <div class="">

            </div>
            <div class="">
            </div>
        </div>
    </div>

</section>
