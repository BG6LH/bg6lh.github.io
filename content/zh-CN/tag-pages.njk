	<div class="mx-auto max-w-4xl p-0">
		<div class="mx-auto p-6 my-0 text-2xl font-bold">
			<h1>Tagged “{{ tag }}”</h1>
		</div>
	</div>
	<div class="mx-auto px-4 prose prose-neutral ">



{% set postslist = collections[ tag ] %}
{% include "postslist.njk" %}

<p>See <a href="{{page.lang}}/tags.njk">all tags</a>.</p>


	</div>
</section>