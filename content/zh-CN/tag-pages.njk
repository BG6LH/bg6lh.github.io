---js
// <script>
const pagination = {
	data: "collections",
	size: 1,
	alias: "tag",
	filter: ["all", "posts"],
	// addAllPagesToCollections: true,
};

const eleventyExcludeFromCollections = true;
const layout = "layouts/home.njk";
const lang = "zh-CN";


const eleventyComputed = {
	title: "Tagged '{{ tag }}'",
	permalink: function(data) {
		return `/${this.lang}/tags/${this.slugify(data.tag)}/`;
	}
};
---


