---
layout: "layouts/home.njk"
---


<section id="mainContent" class="flex-col mx-auto p-0">
	<div class="mx-auto max-w-4xl p-0">
		<div class="mx-auto p-6 my-0 text-2xl font-bold dark:text-neutral-100">
			<h1>All Tags in my site</h1>
		</div>
	</div>
	<div class="mx-auto px-4 prose dark:prose-invert">



		<ul>
		{% for tag in collections | getKeys | filterTagList | sortAlphabetically %}
			{% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
			<li><a href="/{{ page.lang }}{{ tagUrl }}" class="post-tag">{{ tag }}</a></li>
		{% endfor %}
		</ul>
	
	</div>
</section>

