---js
const eleventyNavigation = {
	key: "Home",
	order: 1
};

const numberOfLatestPostsToShow = 10;
---
<section id="mainContent" class="flex-col mx-auto p-0">
	
	<!-- hero -->
	{% if metadata.hero %}
	{% include "components/hero.njk" %}
	{% endif %}

	<!-- postlist -->
	<div class="mx-auto max-w-4xl p-0">
		{% set postsCount = collections.posts | length %}
		{% set latestPostsCount = postsCount | min(numberOfLatestPostsToShow) %}
		
		<div class="mx-auto p-6 my-0 text-2xl font-bold dark:text-neutral-100">
			<h1>最新文章</h1>
		</div>
		{% set postslist = collections.posts | head(-1 * numberOfLatestPostsToShow) %}
		{% set postslistCounter = postsCount %}
		<div class="mx-auto px-4">
		{% include "postslist.njk" %}
		</div>
	</div>

	<div class="mx-auto px-4">
	{% set morePosts = postsCount - numberOfLatestPostsToShow %}
	{% if morePosts > 0 %}
	<p>{{ morePosts }} more post{% if morePosts != 1 %}s{% endif %} can be found in <a href="/blog.njk">更多博客</a>.</p>
	{% endif %}
	<div>
</section>
